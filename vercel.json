{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "rich-bizness-mobile.vercel.app" }],
      "destination": "https://rich-bizness.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "rich-bizness-llc-rich-bizness-llc.vercel.app" }],
      "destination": "https://rich-bizness.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "rich-bizness-llc-git-main-rich-bizness-llc.vercel.app" }],
      "destination": "https://rich-bizness.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Rich-Bizness-Domains", "value": "rich-bizness.com,www.rich-bizness.com,rich-bizness-mobile-app.vercel.app" },
        { "key": "X-Rich-Bizness-Canonical", "value": "https://rich-bizness.com" }
      ]
    }
  ]
}
