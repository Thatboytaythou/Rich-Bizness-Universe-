{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install --no-audit --no-fund",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {"source": "/portal", "destination": "/", "permanent": true},
    {"source": "/portal.html", "destination": "/", "permanent": true}
  ],
  "rewrites": [
    {"source": "/tap-in", "destination": "/tap-in.html"},{"source": "/profile", "destination": "/profile.html"},{"source": "/edit-profile", "destination": "/edit-profile.html"},{"source": "/settings", "destination": "/settings.html"},{"source": "/notifications", "destination": "/notifications.html"},{"source": "/messages", "destination": "/messages.html"},{"source": "/search", "destination": "/search.html"},{"source": "/upload", "destination": "/upload.html"},{"source": "/creator", "destination": "/creator.html"},{"source": "/admin", "destination": "/admin.html"},{"source": "/feed", "destination": "/feed.html"},{"source": "/gallery", "destination": "/gallery.html"},{"source": "/live", "destination": "/live.html"},{"source": "/watch", "destination": "/watch.html"},{"source": "/music", "destination": "/music.html"},{"source": "/podcast", "destination": "/podcast.html"},{"source": "/radio", "destination": "/radio.html"},{"source": "/sports", "destination": "/sports.html"},{"source": "/store", "destination": "/store.html"},{"source": "/gaming", "destination": "/gaming.html"},{"source": "/meta", "destination": "/meta.html"},{"source": "/avatar", "destination": "/avatar.html"},
    {"source": "/games/rich-chess", "destination": "/rich-chess"},{"source": "/games/rich-chess/", "destination": "/rich-chess"},{"source": "/games/smoke-room-cards", "destination": "/smoke-room-cards"},{"source": "/games/smoke-room-cards/", "destination": "/smoke-room-cards"},{"source": "/games/dj-radio-run", "destination": "/dj-radio-run"},{"source": "/games/dj-radio-run/", "destination": "/dj-radio-run"},{"source": "/games/money-road-runner", "destination": "/money-road-runner"},{"source": "/games/money-road-runner/", "destination": "/money-road-runner"},{"source": "/games/rich-samurais-son-ninja", "destination": "/rich-samurais-son-ninja"},{"source": "/games/rich-samurais-son-ninja/", "destination": "/rich-samurais-son-ninja"},{"source": "/games/aura-shinobi-clash", "destination": "/aura-shinobi-clash"},{"source": "/games/aura-shinobi-clash/", "destination": "/aura-shinobi-clash"},{"source": "/games/boss-walk-battle", "destination": "/boss-walk-battle"},{"source": "/games/boss-walk-battle/", "destination": "/boss-walk-battle"},{"source": "/games/smoke-burst-arena", "destination": "/smoke-burst-arena"},{"source": "/games/smoke-burst-arena/", "destination": "/smoke-burst-arena"},{"source": "/games/hero-villain-showdown", "destination": "/hero-villain-showdown"},{"source": "/games/hero-villain-showdown/", "destination": "/hero-villain-showdown"},{"source": "/games/empire-builder", "destination": "/empire-builder"},{"source": "/games/empire-builder/", "destination": "/empire-builder"},{"source": "/games/market-flip", "destination": "/market-flip"},{"source": "/games/market-flip/", "destination": "/market-flip"}
  ],
  "headers": [
    {"source": "/api/(.*)", "headers": [{"key": "Cache-Control", "value": "no-store"},{"key": "X-Content-Type-Options", "value": "nosniff"}]},
    {"source": "/(.*)", "headers": [{"key": "X-Content-Type-Options", "value": "nosniff"},{"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"},{"key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=()"},{"key": "Cross-Origin-Opener-Policy", "value": "same-origin"}]}
  ]
}