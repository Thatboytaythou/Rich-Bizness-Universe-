{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install --no-audit --no-fund",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/portal", "destination": "/portal.html" },
    { "source": "/tap-in", "destination": "/tap-in.html" },
    { "source": "/profile", "destination": "/profile.html" },
    { "source": "/edit-profile", "destination": "/edit-profile.html" },
    { "source": "/settings", "destination": "/settings.html" },
    { "source": "/notifications", "destination": "/notifications.html" },
    { "source": "/messages", "destination": "/messages.html" },
    { "source": "/search", "destination": "/search.html" },
    { "source": "/upload", "destination": "/upload.html" },
    { "source": "/creator", "destination": "/creator.html" },
    { "source": "/creator-dimensions", "destination": "/creator-dimensions.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/feed", "destination": "/feed.html" },
    { "source": "/gallery", "destination": "/gallery.html" },
    { "source": "/live", "destination": "/live.html" },
    { "source": "/watch", "destination": "/watch.html" },
    { "source": "/music", "destination": "/music.html" },
    { "source": "/podcast", "destination": "/podcast.html" },
    { "source": "/radio", "destination": "/radio.html" },
    { "source": "/sports", "destination": "/sports.html" },
    { "source": "/store", "destination": "/store.html" },
    { "source": "/gaming", "destination": "/gaming.html" },
    { "source": "/meta", "destination": "/meta.html" },
    { "source": "/avatar", "destination": "/avatar.html" },
    { "source": "/avatar-characters", "destination": "/avatar-characters.html" },
    { "source": "/games/rich-chess", "destination": "/rich-chess" },
    { "source": "/games/smoke-room-cards", "destination": "/smoke-room-cards" },
    { "source": "/games/dj-radio-run", "destination": "/dj-radio-run" },
    { "source": "/games/money-road-runner", "destination": "/money-road-runner" },
    { "source": "/games/rich-samurais-son-ninja", "destination": "/rich-samurais-son-ninja" },
    { "source": "/games/aura-shinobi-clash", "destination": "/aura-shinobi-clash" },
    { "source": "/games/boss-walk-battle", "destination": "/boss-walk-battle" },
    { "source": "/games/smoke-burst-arena", "destination": "/smoke-burst-arena" },
    { "source": "/games/hero-villain-showdown", "destination": "/hero-villain-showdown" },
    { "source": "/games/empire-builder", "destination": "/empire-builder" },
    { "source": "/games/market-flip", "destination": "/market-flip" },
    { "source": "/games/vault-unlock", "destination": "/vault-unlock" },
    { "source": "/games/portal-room-rush", "destination": "/portal-room-rush" },
    { "source": "/games/avatar-free-roam", "destination": "/avatar-free-roam" },
    { "source": "/games/smoke-city-hustle", "destination": "/smoke-city-hustle" },
    { "source": "/games/treehouse-ride", "destination": "/treehouse-ride" },
    { "source": "/games/studio-showdown", "destination": "/studio-showdown" },
    { "source": "/games/rich-court-king", "destination": "/rich-court-king" },
    { "source": "/games/diamond-bat-flip", "destination": "/diamond-bat-flip" },
    { "source": "/games/golf-green-gold", "destination": "/golf-green-gold" },
    { "source": "/games/gym-grind-reps", "destination": "/gym-grind-reps" },
    { "source": "/games/cash-rain-catcher", "destination": "/cash-rain-catcher" },
    { "source": "/games/portal-dash", "destination": "/portal-dash" },
    { "source": "/games/bizness-party-room", "destination": "/bizness-party-room" },
    { "source": "/games/rich-color-clash", "destination": "/rich-color-clash" },
    { "source": "/games/rich-spades-royale", "destination": "/rich-spades-royale" },
    { "source": "/games/rich-checkers-elite", "destination": "/rich-checkers-elite" },
    { "source": "/games/crown-connect-four", "destination": "/crown-connect-four" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=(self)" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
